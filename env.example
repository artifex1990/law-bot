# ===== Legal Consultation Bot - пример конфигурации =====
# Скопируйте в .env и/или .env.local и заполните значения:
#   cp env.example .env
#   cp env.example .env.local

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Локально: False (long polling). Продакшен: True (HTTPS webhook)
TELEGRAM_USE_WEBHOOK=False
# Публичный HTTPS URL для setWebhook (если без пути - добавится TELEGRAM_WEBHOOK_PATH)
WEBHOOK_URL=https://bot.example.com
# Локальная привязка сервера под webhook (Telegram допускает порты 443, 80, 88, 8443)
WEBHOOK_LISTEN_HOST=0.0.0.0
WEBHOOK_PORT=8443
# Путь на вашем сервере (nginx проксирует сюда POST от Telegram)
TELEGRAM_WEBHOOK_PATH=/webhook
# Секрет в заголовке X-Telegram-Bot-Api-Secret-Token (A–Z a–z 0–9 _-), рекомендуется
TELEGRAM_WEBHOOK_SECRET=
# При старте сбрасывать необработанные updates (осторожно в проде)
TELEGRAM_WEBHOOK_DROP_PENDING=False

# ---------- MAX Messenger (опционально) ----------
MAX_BOT_TOKEN=

# ---------- Database ----------
# Локально (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./legal_bot.db
# Docker (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://legal_bot:legal_bot_pass@postgres:5432/legal_bot
# DB_USER=legal_bot
# DB_PASSWORD=legal_bot_pass
# DB_NAME=legal_bot

# ---------- AI Models ----------
AI_DEFAULT_MODEL=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
YANDEX_GPT_API_KEY=

# ---------- Logging ----------
DEBUG=True
LOG_LEVEL=INFO

# ---------- Notifications ----------
NOTIFY_ADMIN_ON_CONSULTATION=False
ADMIN_CHAT_ID=
# Telegram user id админов (через запятую), команды /admin /stats /users /export
ADMIN_IDS=

# ---------- Integration HTTP API (CRM, внешние сервисы) ----------
# Вместе с ботом: API_ENABLED=True в .env, затем python -m src.main
# Только API без бота: python -m src.run_api
API_ENABLED=False
API_HOST=0.0.0.0
API_PORT=8080
# Пусто = без проверки заголовков (только доверенная сеть)
INTEGRATION_API_TOKEN=
# Исходящий POST при новой заявке (опционально)
OUTBOUND_WEBHOOK_URL=
OUTBOUND_WEBHOOK_TOKEN=

# ---------- Timeouts ----------
MESSAGE_TIMEOUT=30
CONVERSATION_TIMEOUT=3600

# ---------- Догоняющие напоминания (followup) ----------
# Включить фоновые напоминания неактивным клиентам
FOLLOWUP_ENABLED=True
# Интервал проверки (минуты)
FOLLOWUP_CHECK_INTERVAL_MIN=10
# Через сколько часов отправлять напоминания (JSON-массив)
# Пример: [1, 12, 24, 72] - через 1ч, 12ч, 1 день, 3 дня
FOLLOWUP_INTERVALS_HOURS=[1, 12, 24, 72]
# Тексты напоминаний (JSON-массив строк, по одному на интервал)
# Если не задано - используются встроенные тексты
# FOLLOWUP_MESSAGES=["Текст 1","Текст 2","Текст 3","Текст 4"]

# ---------- Backups ----------
# Включить авто-бэкапы БД
BACKUP_ENABLED=True
# Тип хранилища: local | ftp | s3
BACKUP_STORAGE_TYPE=local
# Интервал (часы)
BACKUP_INTERVAL_HOURS=1
# Хранить бэкапы (дни)
BACKUP_RETENTION_DAYS=30

# -- Local --
BACKUP_LOCAL_PATH=./backups

# -- FTP / FTPS --
BACKUP_FTP_HOST=ftp.example.com
BACKUP_FTP_PORT=21
BACKUP_FTP_USER=backup_user
BACKUP_FTP_PASSWORD=secret
BACKUP_FTP_PATH=/backups
BACKUP_FTP_TLS=False

# -- S3-совместимое облако --
# AWS S3:       BACKUP_S3_ENDPOINT оставьте пустым
# MinIO:        BACKUP_S3_ENDPOINT=https://minio.example.com:9000
# Yandex Cloud: BACKUP_S3_ENDPOINT=https://storage.yandexcloud.net
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=my-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=ru-central1
BACKUP_S3_PREFIX=backups
