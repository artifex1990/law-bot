# Скопируйте в .env и заполните значения
# cp env.example .env

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_USE_WEBHOOK=False
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PORT=8443

# MAX Messenger
MAX_BOT_TOKEN=your_max_bot_token_here

# Database (SQLite для локальной разработки)
# Для локальной разработки:
DATABASE_URL=sqlite+aiosqlite:///./legal_bot.db
# Для Docker с PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://legal_bot:legal_bot_pass@postgres:5432/legal_bot
# DB_USER=legal_bot
# DB_PASSWORD=legal_bot_pass
# DB_NAME=legal_bot

# AI Models
AI_DEFAULT_MODEL=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
YANDEX_GPT_API_KEY=

# Logging
DEBUG=True
LOG_LEVEL=INFO

# Notifications
NOTIFY_ADMIN_ON_CONSULTATION=False
ADMIN_CHAT_ID=

# Timeouts
MESSAGE_TIMEOUT=30
CONVERSATION_TIMEOUT=3600
