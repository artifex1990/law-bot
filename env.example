# ===== Legal Consultation Bot — пример конфигурации =====
# Скопируйте в .env и/или .env.local и заполните значения:
#   cp env.example .env
#   cp env.example .env.local

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_USE_WEBHOOK=False
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PORT=8443

# ---------- MAX Messenger (опционально) ----------
MAX_BOT_TOKEN=

# ---------- Database ----------
# Локально (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./legal_bot.db
# Docker (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://legal_bot:legal_bot_pass@postgres:5432/legal_bot
# DB_USER=legal_bot
# DB_PASSWORD=legal_bot_pass
# DB_NAME=legal_bot

# ---------- AI Models ----------
AI_DEFAULT_MODEL=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
YANDEX_GPT_API_KEY=

# ---------- Logging ----------
DEBUG=True
LOG_LEVEL=INFO

# ---------- Notifications ----------
NOTIFY_ADMIN_ON_CONSULTATION=False
ADMIN_CHAT_ID=

# ---------- Timeouts ----------
MESSAGE_TIMEOUT=30
CONVERSATION_TIMEOUT=3600

# ---------- Backups ----------
# Включить авто-бэкапы БД
BACKUP_ENABLED=True
# Тип хранилища: local | ftp | s3
BACKUP_STORAGE_TYPE=local
# Интервал (часы)
BACKUP_INTERVAL_HOURS=1
# Хранить бэкапы (дни)
BACKUP_RETENTION_DAYS=30

# -- Local --
BACKUP_LOCAL_PATH=./backups

# -- FTP / FTPS --
BACKUP_FTP_HOST=ftp.example.com
BACKUP_FTP_PORT=21
BACKUP_FTP_USER=backup_user
BACKUP_FTP_PASSWORD=secret
BACKUP_FTP_PATH=/backups
BACKUP_FTP_TLS=False

# -- S3-совместимое облако --
# AWS S3:       BACKUP_S3_ENDPOINT оставьте пустым
# MinIO:        BACKUP_S3_ENDPOINT=https://minio.example.com:9000
# Yandex Cloud: BACKUP_S3_ENDPOINT=https://storage.yandexcloud.net
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=my-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=ru-central1
BACKUP_S3_PREFIX=backups
